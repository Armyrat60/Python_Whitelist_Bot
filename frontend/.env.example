# URL of the TypeScript API backend — set this in production to the Railway service URL.
# Empty string means Next.js will proxy /api/* to the same origin (relies on rewrites below).
NEXT_PUBLIC_API_URL=

# For local development, point directly to the TypeScript API:
# NEXT_PUBLIC_API_URL=http://localhost:8080

# Server-side: the internal/private URL Next.js uses for rewrites.
# In Railway: set this to the private network URL of the api/ service,
# e.g. http://squadwhitelister-api.railway.internal:8080
BACKEND_URL=http://localhost:8080
