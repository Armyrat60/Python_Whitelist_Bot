generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BotSetting {
  guildId      BigInt @map("guild_id")
  settingKey   String @map("setting_key") @db.VarChar(100)
  settingValue String @map("setting_value")

  @@id([guildId, settingKey])
  @@map("bot_settings")
}

model Whitelist {
  id               Int      @id @default(autoincrement())
  guildId          BigInt   @map("guild_id")
  name             String   @db.VarChar(100)
  slug             String   @db.VarChar(50)
  enabled          Boolean  @default(false)
  panelChannelId   BigInt?  @map("panel_channel_id")
  panelMessageId   BigInt?  @map("panel_message_id")
  logChannelId     BigInt?  @map("log_channel_id")
  squadGroup       String   @default("Whitelist") @map("squad_group") @db.VarChar(100)
  outputFilename   String   @default("whitelist.txt") @map("output_filename") @db.VarChar(255)
  defaultSlotLimit Int      @default(1) @map("default_slot_limit")
  stackRoles       Boolean  @default(false) @map("stack_roles")
  isDefault        Boolean  @default(false) @map("is_default")
  isManual         Boolean  @default(false) @map("is_manual")
  createdAt        DateTime @map("created_at")
  updatedAt        DateTime @map("updated_at")

  panels          Panel[]
  users           WhitelistUser[]
  identifiers     WhitelistIdentifier[]
  categories      WhitelistCategory[]

  @@unique([guildId, slug])
  @@map("whitelists")
}

model WhitelistCategory {
  id          Int      @id @default(autoincrement())
  guildId     BigInt   @map("guild_id")
  whitelistId Int      @map("whitelist_id")
  name        String   @db.VarChar(100)
  slotLimit   Int?     @map("slot_limit")
  sortOrder   Int      @default(0) @map("sort_order")
  squadGroup  String?  @map("squad_group") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  whitelist Whitelist          @relation(fields: [whitelistId], references: [id], onDelete: Cascade)
  managers  CategoryManager[]
  users     WhitelistUser[]

  @@unique([whitelistId, name])
  @@map("whitelist_categories")
}

model CategoryManager {
  id          Int      @id @default(autoincrement())
  categoryId  Int      @map("category_id")
  discordId   BigInt   @map("discord_id")
  discordName String   @map("discord_name") @db.VarChar(255)
  addedAt     DateTime @default(now()) @map("added_at")

  category WhitelistCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, discordId])
  @@map("category_managers")
}

model PanelRole {
  id          Int      @id @default(autoincrement())
  guildId     BigInt   @map("guild_id")
  panelId     Int      @map("panel_id")
  roleId      BigInt   @map("role_id")
  roleName    String   @map("role_name") @db.VarChar(100)
  slotLimit   Int      @default(1) @map("slot_limit")
  isStackable Boolean  @default(false) @map("is_stackable")
  isActive    Boolean  @default(true) @map("is_active")
  displayName String?  @map("display_name") @db.VarChar(100)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  panel       Panel @relation(fields: [panelId], references: [id], onDelete: Cascade)

  @@unique([guildId, panelId, roleId])
  @@map("panel_roles")
}

model WhitelistUser {
  guildId            BigInt   @default(0) @map("guild_id")
  discordId          BigInt   @map("discord_id")
  whitelistType      String?  @map("whitelist_type") @db.VarChar(20)
  whitelistId        Int      @map("whitelist_id")
  discordName        String   @map("discord_name") @db.VarChar(255)
  status             String   @default("active") @db.VarChar(50)
  slotLimitOverride  Int?     @map("slot_limit_override")
  effectiveSlotLimit Int      @default(0) @map("effective_slot_limit")
  lastPlanName       String?  @map("last_plan_name") @db.VarChar(255)
  updatedAt          DateTime @map("updated_at")
  createdAt          DateTime @map("created_at")
  expiresAt          DateTime? @map("expires_at")
  createdVia         String?  @map("created_via") @db.VarChar(50)
  notes              String?  @db.VarChar(500)
  categoryId         Int?     @map("category_id")
  discordUsername    String?  @map("discord_username") @db.VarChar(255)
  discordNick        String?  @map("discord_nick") @db.VarChar(255)
  clanTag            String?  @map("clan_tag") @db.VarChar(50)
  category           WhitelistCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  whitelist          Whitelist @relation(fields: [whitelistId], references: [id])

  @@id([guildId, discordId, whitelistId])
  @@map("whitelist_users")
}

model WhitelistIdentifier {
  id                 Int      @id @default(autoincrement())
  guildId            BigInt   @default(0) @map("guild_id")
  discordId          BigInt   @map("discord_id")
  whitelistType      String?  @map("whitelist_type") @db.VarChar(20)
  whitelistId        Int?     @map("whitelist_id")
  idType             String   @map("id_type") @db.VarChar(20)
  idValue            String   @map("id_value") @db.VarChar(255)
  isVerified         Boolean  @default(false) @map("is_verified")
  verificationSource String?  @map("verification_source") @db.VarChar(100)
  createdAt          DateTime @map("created_at")
  updatedAt          DateTime @map("updated_at")

  whitelist          Whitelist? @relation(fields: [whitelistId], references: [id], onDelete: SetNull)

  @@unique([guildId, discordId, whitelistId, idType, idValue])
  @@map("whitelist_identifiers")
}

model AuditLog {
  id              Int      @id @default(autoincrement())
  guildId         BigInt   @default(0) @map("guild_id")
  whitelistType   String?  @map("whitelist_type") @db.VarChar(20)
  whitelistId     Int?     @map("whitelist_id")
  actionType      String   @map("action_type") @db.VarChar(100)
  actorDiscordId  BigInt?  @map("actor_discord_id")
  targetDiscordId BigInt?  @map("target_discord_id")
  details         String?
  createdAt       DateTime @map("created_at")

  @@index([guildId, createdAt(sort: Desc)])
  @@map("audit_log")
}

model SquadPermission {
  permission  String  @id @db.VarChar(50)
  description String  @db.VarChar(255)
  isActive    Boolean @default(true) @map("is_active")

  @@map("squad_permissions")
}

model SquadGroup {
  guildId     BigInt   @default(0) @map("guild_id")
  groupName   String   @map("group_name") @db.VarChar(100)
  permissions String
  description String   @default("") @db.VarChar(255)
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")

  @@id([guildId, groupName])
  @@map("squad_groups")
}

model Panel {
  id               Int      @id @default(autoincrement())
  guildId          BigInt   @default(0) @map("guild_id")
  name             String   @db.VarChar(100)
  channelId        BigInt?  @map("channel_id")
  logChannelId     BigInt?  @map("log_channel_id")
  whitelistId      Int?     @map("whitelist_id")
  panelMessageId   BigInt?  @map("panel_message_id")
  isDefault        Boolean  @default(false) @map("is_default")
  enabled          Boolean  @default(true)
  showRoleMentions Boolean   @default(true) @map("show_role_mentions")
  lastPushStatus   String?   @map("last_push_status") @db.VarChar(20)
  lastPushError    String?   @map("last_push_error")
  lastPushAt       DateTime? @map("last_push_at")
  createdAt        DateTime  @map("created_at")
  updatedAt        DateTime  @map("updated_at")

  whitelist        Whitelist? @relation(fields: [whitelistId], references: [id], onDelete: SetNull)
  panelRoles       PanelRole[]

  @@map("panels")
}

model PanelRefreshQueue {
  id        Int      @id @default(autoincrement())
  guildId   BigInt   @map("guild_id")
  panelId   Int      @map("panel_id")
  reason    String   @default("settings_changed") @db.VarChar(200)
  action    String   @default("refresh") @db.VarChar(20)
  channelId BigInt?  @map("channel_id")
  messageId BigInt?  @map("message_id")
  createdAt DateTime @default(now()) @map("created_at")
  processed Boolean  @default(false)

  @@map("panel_refresh_queue")
}

model NotificationRouting {
  guildId   BigInt @default(0) @map("guild_id")
  eventType String @map("event_type") @db.VarChar(50)
  channelId String @default("") @map("channel_id") @db.VarChar(20)

  @@id([guildId, eventType])
  @@map("notification_routing")
}

model DashboardPermission {
  id              Int      @id @default(autoincrement())
  guildId         BigInt   @map("guild_id")
  discordId       String   @map("discord_id") @db.VarChar(32)
  discordName     String?  @map("discord_name") @db.VarChar(100)
  permissionLevel String   @default("viewer") @map("permission_level") @db.VarChar(20)
  grantedBy       String?  @map("granted_by") @db.VarChar(32)
  grantedAt       DateTime @default(now()) @map("granted_at")

  @@unique([guildId, discordId])
  @@index([guildId])
  @@map("dashboard_permissions")
}

model DashboardRolePermission {
  id              Int      @id @default(autoincrement())
  guildId         BigInt   @map("guild_id")
  roleId          String   @map("role_id") @db.VarChar(32)
  roleName        String?  @map("role_name") @db.VarChar(100)
  permissionLevel String   @default("viewer") @map("permission_level") @db.VarChar(20)
  grantedBy       String?  @map("granted_by") @db.VarChar(32)
  grantedAt       DateTime @default(now()) @map("granted_at")

  @@unique([guildId, roleId])
  @@index([guildId])
  @@map("dashboard_role_permissions")
}

model SteamNameCache {
  steamId     String   @id @map("steam_id") @db.VarChar(20)
  personaName String   @map("persona_name") @db.VarChar(255)
  cachedAt    DateTime @map("cached_at")

  @@map("steam_name_cache")
}

model BridgeConfig {
  id                  Int       @id @default(autoincrement())
  guildId             BigInt    @unique @map("guild_id")
  mysqlHost           String    @map("mysql_host") @db.VarChar(255)
  mysqlPort           Int       @default(3306) @map("mysql_port")
  mysqlDatabase       String    @map("mysql_database") @db.VarChar(255)
  mysqlUser           String    @map("mysql_user") @db.VarChar(255)
  mysqlPassword       String    @map("mysql_password") @db.VarChar(500)
  serverName          String    @default("Game Server") @map("server_name") @db.VarChar(255)
  syncIntervalMinutes Int       @default(15) @map("sync_interval_minutes")
  enabled             Boolean   @default(true)
  lastSyncAt          DateTime? @map("last_sync_at")
  lastSyncStatus      String?   @map("last_sync_status") @db.VarChar(20)
  lastSyncMessage     String?   @map("last_sync_message")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("bridge_configs")
}

model JobQueue {
  id          Int       @id @default(autoincrement())
  guildId     BigInt    @map("guild_id")
  jobType     String    @map("job_type") @db.VarChar(50)
  payload     Json      @default("{}")
  status      String    @default("pending") @db.VarChar(20)
  priority    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  result      Json?
  error       String?

  @@index([guildId, status])
  @@index([status, priority, createdAt])
  @@map("job_queue")
}

model SquadPlayer {
  id           Int      @id @default(autoincrement())
  guildId      BigInt   @map("guild_id")
  steamId      String   @map("steam_id") @db.VarChar(32)
  lastSeenName String?  @map("last_seen_name") @db.VarChar(255)
  serverName   String?  @map("server_name") @db.VarChar(255)
  firstSeenAt  DateTime @default(now()) @map("first_seen_at")
  lastSeenAt   DateTime @default(now()) @map("last_seen_at")
  discordId    BigInt?  @map("discord_id")

  @@unique([guildId, steamId])
  @@index([guildId])
  @@index([discordId])
  @@map("squad_players")
}

// ─── Seeding Module ─────────────────────────────────────────────────────────

model SeedingConfig {
  id                      Int       @id @default(autoincrement())
  guildId                 BigInt    @unique @map("guild_id")
  enabled                 Boolean   @default(false)
  squadjsHost             String    @default("") @map("squadjs_host") @db.VarChar(255)
  squadjsPort             Int       @default(3000) @map("squadjs_port")
  squadjsToken            String    @default("") @map("squadjs_token") @db.VarChar(500)
  seedingStartPlayerCount Int       @default(2) @map("seeding_start_player_count")
  seedingPlayerThreshold  Int       @default(50) @map("seeding_player_threshold")
  pointsRequired          Int       @default(120) @map("points_required")
  rewardWhitelistId       Int?      @map("reward_whitelist_id")
  rewardGroupName         String    @default("SeedReserve") @map("reward_group_name") @db.VarChar(100)
  rewardDurationHours     Int       @default(168) @map("reward_duration_hours")
  trackingMode            String    @default("fixed_reset") @map("tracking_mode") @db.VarChar(20)
  resetCron               String    @default("0 0 * * *") @map("reset_cron") @db.VarChar(50)
  pollIntervalSeconds     Int       @default(60) @map("poll_interval_seconds")
  seedingWindowEnabled    Boolean   @default(false) @map("seeding_window_enabled")
  seedingWindowStart      String    @default("07:00") @map("seeding_window_start") @db.VarChar(5)
  seedingWindowEnd        String    @default("22:00") @map("seeding_window_end") @db.VarChar(5)
  lastPollAt              DateTime? @map("last_poll_at")
  lastPollStatus          String?   @map("last_poll_status") @db.VarChar(20)
  lastPollMessage         String?   @map("last_poll_message")
  rewardTiers             Json?     @map("reward_tiers")
  rconWarningsEnabled     Boolean   @default(false) @map("rcon_warnings_enabled")
  rconWarningMessage      String    @default("Seeding Progress: {progress}% ({points}/{required}). Keep seeding!") @map("rcon_warning_message")
  decayDaysThreshold      Int       @default(3) @map("decay_days_threshold")
  decayPointsPerDay       Int       @default(10) @map("decay_points_per_day")
  discordRoleRewardEnabled  Boolean  @default(false) @map("discord_role_reward_enabled")
  discordRoleRewardId       String?  @map("discord_role_reward_id") @db.VarChar(32)
  discordRemoveRoleOnExpiry Boolean  @default(false) @map("discord_remove_role_on_expiry")
  autoSeedAlertEnabled      Boolean  @default(false) @map("auto_seed_alert_enabled")
  autoSeedAlertRoleId       String?  @map("auto_seed_alert_role_id") @db.VarChar(32)
  autoSeedAlertCooldownMin  Int      @default(30) @map("auto_seed_alert_cooldown_min")
  discordNotifyChannelId    String?  @map("discord_notify_channel_id") @db.VarChar(32)
  leaderboardPublic       Boolean   @default(false) @map("leaderboard_public")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@map("seeding_configs")
}

model SeedingNotification {
  id        Int      @id @default(autoincrement())
  guildId   BigInt   @map("guild_id")
  eventType String   @map("event_type") @db.VarChar(50)
  payload   Json     @default("{}")
  processed Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([guildId, processed, createdAt])
  @@map("seeding_notifications")
}

model SeedingPoints {
  id          Int       @id @default(autoincrement())
  guildId     BigInt    @map("guild_id")
  steamId     String    @map("steam_id") @db.VarChar(32)
  playerName  String?   @map("player_name") @db.VarChar(255)
  points      Int       @default(0)
  lastAwardAt DateTime? @map("last_award_at")
  lastResetAt DateTime? @map("last_reset_at")
  rewarded    Boolean   @default(false)
  rewardedAt  DateTime? @map("rewarded_at")

  @@unique([guildId, steamId])
  @@index([guildId, points(sort: Desc)])
  @@map("seeding_points")
}

model SeedingSession {
  id           Int       @id @default(autoincrement())
  guildId      BigInt    @map("guild_id")
  steamId      String    @map("steam_id") @db.VarChar(32)
  playerName   String?   @map("player_name") @db.VarChar(255)
  startedAt    DateTime  @map("started_at")
  endedAt      DateTime? @map("ended_at")
  pointsEarned Int       @default(0) @map("points_earned")
  playerCount  Int       @default(0) @map("player_count")

  @@index([guildId, startedAt(sort: Desc)])
  @@index([guildId, steamId])
  @@map("seeding_sessions")
}
