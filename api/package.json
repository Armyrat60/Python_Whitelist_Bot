{
  "name": "squadwhitelister-api",
  "version": "1.0.2",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:deploy": "node scripts/check-destructive-migration.mjs && prisma migrate deploy",
    "db:push": "prisma db push",
    "db:drift": "node scripts/check-prod-drift.mjs",
    "db:backup": "node scripts/backup-prod.mjs",
    "db:backup:list": "node scripts/restore-prod.mjs --list",
    "db:restore": "node scripts/restore-prod.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/session": "^11.1.1",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.48.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "mysql2": "^3.20.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "prisma": "^6.19.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
}
