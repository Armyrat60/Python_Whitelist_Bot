# ── Required ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=

# ── OAuth2 (for /login → /callback flow) ─────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Public URL of the frontend (used for OAuth2 redirect and CORS)
# In Railway: set this to the frontend service URL, e.g. https://yourapp.railway.app
WEB_BASE_URL=http://localhost:3000

# ── Security ─────────────────────────────────────────────────────────────────
# Secret for signing session cookies — generate with: openssl rand -hex 32
WEB_SESSION_SECRET=change-me

# Shared secret for internal /internal/* sync calls (bot → api)
WEB_FILE_SECRET=

# Allowed CORS origin — set to WEB_BASE_URL in production
# CORS_ORIGIN=https://yourapp.railway.app

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
NODE_ENV=production
